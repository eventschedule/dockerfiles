APP_NAME=EventSchedule
APP_ENV=production
#APP_ENV=local
APP_DEBUG=false

# A throwaway key is generated automatically on first start. For production, or to keep
# sessions valid across container restarts, set a fixed key once: uncomment APP_KEY below
# and paste the output of the following (it is then shared by the app and scheduler via
# env_file). Leave it commented for a generated, ephemeral key.
#   docker compose run --rm app php artisan key:generate --show
# APP_KEY=

# URL where the app is reached. Defaults to the local compose port; change it for any
# real deployment or generated links and emails will point to localhost.
APP_URL=http://localhost:8080

FORCE_HTTPS=false
SESSION_SECURE_COOKIE=false

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=eventschedule
DB_USERNAME=eventschedule
DB_PASSWORD=change_me

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

