APP_NAME=EventSchedule
# "local" matches the default http://localhost setup. EventSchedule forces HTTPS whenever
# APP_ENV is not "local", so for a real deployment set this to "production" AND serve the
# app over HTTPS (e.g. behind a TLS-terminating proxy), otherwise links and redirects break.
APP_ENV=local
#APP_ENV=production
APP_DEBUG=false

# An APP_KEY is generated into the image when it is built, so it is stable across
# container restarts but changes whenever you rebuild the image (invalidating existing
# sessions and encrypted data). For a key that survives rebuilds, uncomment APP_KEY below
# and set it to the output of the following (it then overrides the built-in key for the
# app and scheduler via env_file):
#   docker compose run --rm app php artisan key:generate --show
# APP_KEY=

# URL where the app is reached. Defaults to the local compose port; change it for any
# real deployment or generated links and emails will point to localhost.
APP_URL=http://localhost:8080

# Keep false for the http://localhost setup; the session cookie must not require HTTPS.
SESSION_SECURE_COOKIE=false

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=eventschedule
DB_USERNAME=eventschedule
DB_PASSWORD=change_me

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

